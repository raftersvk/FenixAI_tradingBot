# ==============================================================================
# FenixAI Trading Bot — Environment Variables Reference
# ==============================================================================
# Copiez ce fichier en `.env` et remplissez les valeurs réelles.
#
# ⚠️  RÈGLES D'OR :
#   - Les SECRETS (clés API) sont TOUJOURS dans .env (jamais dans YAML)
#   - Les CONFIGS opérationnelles sont dans YAML (fenix.yaml, llm_providers.yaml)
#   - Les FLAGS de déploiement peuvent rester en .env
#
# Priorité de configuration :
#   1. Variables d'environnement (secrets, overrides d'urgence)
#   2. Fichiers YAML (config/fenix.yaml, config/llm_providers.yaml)
#   3. Valeurs par défaut du code
# ==============================================================================

# ==============================================================================
# 1. CREDENTIALS BINANCE (REQUIS)
# ==============================================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Optionnel : clés distinctes pour testnet (si non définies, utilise les main keys)
# BINANCE_TESTNET_API_KEY=
# BINANCE_TESTNET_API_SECRET=

# ==============================================================================
# 2. AUTHENTICATION (REQUIS)
# ==============================================================================
JWT_SECRET=your_jwt_secret_here_change_in_production_min_32_chars

# ==============================================================================
# 3. LLM PROVIDER API KEYS (OPTIONNELS — selon les providers activés)
# ==============================================================================
# Au moins un provider doit être configuré dans config/llm_providers.yaml
# et sa clé API fournie ici.

# OpenAI (si utilisé)
# OPENAI_API_KEY=sk-...

# Anthropic (si utilisé)
# ANTHROPIC_API_KEY=sk-...

# Groq (si utilisé)
# GROQ_API_KEY=gsk_...

# HuggingFace (gratuit, recommandé)
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# Ollama Cloud (alternative payante)
OLLAMA_API_KEY=your_ollama_cloud_key
OLLAMA_HOST=http://localhost:11434           # Pour Ollama local
OLLAMA_CLOUD_URL=https://ollama.com          # Pour Ollama Cloud

# ==============================================================================
# 4. APPLICATION FLAGS (OPTIONNELS)
# ==============================================================================
ENVIRONMENT=development                     # development | staging | production
# LOG_LEVEL est maintenant dans fenix.yaml → logging.level
# Si besoin d'override temporaire, décommenter :
# LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR
ALLOW_EXPOSE_API=false                      # true = API exposée publiquement (dangereux)
CORS_ALLOWED_ORIGINS=*                      # Origines CORS autorisées ("," séparé)
CREATE_DEMO_USERS=true                      # true = crée users de démo (dev uniquement)

# ==============================================================================
# 5. BASE DE DONNÉES (OPTIONNEL)
# ==============================================================================
DATABASE_URL=sqlite+aiosqlite:///./data/fenix.db

# ==============================================================================
# 6. HYBRID MODEL CONFIG (OPTIONNELS)
# ==============================================================================
ENABLE_API_FALLBACK=true                    # Si provider échoue → fallback local
FORCE_MLX_LOCAL=false                       # Force modèles MLX locaux (Mac)
USE_CLOUD_MODELS=false                      # Force cloud uniquement

# ==============================================================================
# 7. MONITORING & ALERTS (OPTIONNELS)
# ==============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
ENABLE_CIRCUIT_BREAKER_ALERTS=true
MIN_ALERT_LEVEL=SEVERE                     # SEVERE | WARNING | INFO

# ==============================================================================
# 8. OPEN TELEMETRY (OPTIONNEL)
# ==============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_HTTP_ENDPOINT=http://localhost:4318/v1/traces

# ==============================================================================
# 9. MLX / CACHE (OPTIONNELS)
# ==============================================================================
MLX_DISABLED=0                             # 1 = désactiver MLX (bug workaround)
MLX_HOME=                                  # Dossier des modèles MLX (défaut: ~/.cache/mlx)
HF_HOME=~/.cache/huggingface               # Cache HuggingFace
HUGGINGFACE_HUB_CACHE=                     # Alternative cache HF

# ==============================================================================
# 10. JUDGE OVERRIDES (TRÈS OPTIONNELS — override d'urgence)
# ==============================================================================
# Par défaut, le judge est configuré dans config/llm_providers.yaml.
# Ces variables ne sont utilisées QUE si llm_providers.yaml est inaccessible.
# En production normale, NE PAS UTILISER ces variables.
# FENIX_JUDGE_PROVIDER=ollama_local
# FENIX_JUDGE_MODEL=qwen3:8b
# FENIX_JUDGE_TEMPERATURE=0.1
# FENIX_JUDGE_MAX_TOKENS=512
# FENIX_JUDGE_SYSTEM_PROMPT="You are a strict auditor..."

# ==============================================================================
# 11. SECRETS MANAGER (INTERNE)
# ==============================================================================
# SECRETS_PASSWORD=...                     # Pour dérivation de clés (interne)

# ==============================================================================
# 12. DÉPRÉCIÉS / OBSOLÈTES (NE PAS UTILISER — listés pour référence)
# ==============================================================================
# Les variables suivantes sont TOTALEMENT OBSOLÈTES et ont été supprimées :
#   DEFAULT_SYMBOL, MAX_POSITION_SIZE, MAX_DAILY_LOSS, STOP_LOSS_PERCENTAGE,
#   TAKE_PROFIT_PERCENTAGE, TRADING_MODE, PRIMARY_TIMEFRAME, SECONDARY_TIMEFRAME,
#   ANALYSIS_TIMEFRAME, ENABLE_BACKTESTING, ENABLE_PAPER_TRADING,
#   ENABLE_SENTIMENT_AGENT, ENABLE_TECHNICAL_AGENT, ENABLE_VISUAL_AGENT,
#   ENABLE_QABBA_AGENT, ENABLE_RISK_AGENT, ENABLE_EMAIL_ALERTS,
#   ENABLE_SMS_ALERTS, ENABLE_PUSH_NOTIFICATIONS, BACKUP_INTERVAL,
#   BACKUP_RETENTION_DAYS, AUTO_BACKUP, MAX_WORKERS, CACHE_TTL, BATCH_SIZE,
#   DISABLE_TENSORFLOW, SECRET_KEY, FENIX_LOAD_LEGACY_SYSTEM, HF_TOKEN,
#   HUGGINGFACEHUB_API_TOKEN
# ==============================================================================
